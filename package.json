{
  "name": "@~lyre/ai-agents",
  "version": "0.2.0",
  "description": "Multi-provider AI agents SDK for SvelteKit + Node. Thin agent/tool/run/runStream surface over the Vercel AI SDK — OpenAI, Anthropic, Google Gemini, Mistral, Cohere. Zod-typed tools, full streaming event surface, optional HTML sanitizer.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "Britam Trust Services / Lyre",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kigathi-chege/lyre-packages.git",
    "directory": "packages/ai-agents"
  },
  "homepage": "https://github.com/kigathi-chege/lyre-packages/tree/main/packages/ai-agents#readme",
  "bugs": {
    "url": "https://github.com/kigathi-chege/lyre-packages/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "openai",
    "anthropic",
    "google-gemini",
    "vercel-ai-sdk",
    "tools",
    "agents",
    "streaming",
    "sveltekit",
    "lyre"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "import": "./dist/sanitize.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/sanitize.ts --format esm --dts --clean",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "ai": "^6.0.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.2",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
